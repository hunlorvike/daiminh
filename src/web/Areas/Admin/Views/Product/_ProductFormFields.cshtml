@using web.Areas.Admin.ViewModels.Product
@model ProductViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@functions {
	public string GetAntiXsrfRequestToken()
	{
		return Xsrf.GetAndStoreTokens(Context).RequestToken!;
	}
}

@if (Model.Id > 0)
{
	<input type="hidden" asp-for="Id" />
}

<div class="row g-3 mb-4">
	<div class="col-md-8">
		<div class="form-group mb-3">
			<label asp-for="Name" class="form-label required"></label>
			<input asp-for="Name" class="form-control" />
			<span asp-validation-for="Name" class="text-danger"></span>
		</div>

		<div class="form-group mb-3">
			<label asp-for="Slug" class="form-label required"></label>
			<div class="input-group">
				<input asp-for="Slug" class="form-control" />
				<button class="btn btn-outline-secondary" type="button" id="generateSlugButton" title="Tạo slug tự động">
					<i class="ti ti-refresh"></i>
				</button>
			</div>
			<span asp-validation-for="Slug" class="text-danger"></span>
			<small class="form-hint">Dùng cho URL (chỉ chứa chữ cái thường, số và dấu gạch ngang). Phải là duy nhất.</small>
		</div>

		<div class="form-group mb-3">
			<label asp-for="ShortDescription" class="form-label"></label>
			<textarea asp-for="ShortDescription" class="form-control" rows="3"></textarea>
			<span asp-validation-for="ShortDescription" class="text-danger"></span>
		</div>

		<div class="form-group mb-3">
			<label asp-for="Description" class="form-label required"></label>
			<textarea asp-for="Description" class="form-control wysiwyg" rows="10"></textarea>
			<span asp-validation-for="Description" class="text-danger"></span>
		</div>

		<div class="accordion mb-3" id="productOptionalDetailsAccordion">
			<div class="accordion-item">
				<h2 class="accordion-header" id="headingSpecifications">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSpecifications" aria-expanded="false" aria-controls="collapseSpecifications">
						Thông số kỹ thuật
					</button>
				</h2>
				<div id="collapseSpecifications" class="accordion-collapse collapse" aria-labelledby="headingSpecifications" data-bs-parent="#productOptionalDetailsAccordion">
					<div class="accordion-body">
						<div class="form-group">
							<textarea asp-for="Specifications" class="form-control wysiwyg" rows="5"></textarea>
							<span asp-validation-for="Specifications" class="text-danger"></span>
						</div>
					</div>
				</div>
			</div>
			<div class="accordion-item">
				<h2 class="accordion-header" id="headingUsage">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseUsage" aria-expanded="false" aria-controls="collapseUsage">
						Hướng dẫn sử dụng
					</button>
				</h2>
				<div id="collapseUsage" class="accordion-collapse collapse" aria-labelledby="headingUsage" data-bs-parent="#productOptionalDetailsAccordion">
					<div class="accordion-body">
						<div class="form-group">
							<textarea asp-for="Usage" class="form-control wysiwyg" rows="5"></textarea>
							<span asp-validation-for="Usage" class="text-danger"></span>
						</div>
					</div>
				</div>
			</div>
			<div class="accordion-item">
				<h2 class="accordion-header" id="headingFeatures">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFeatures" aria-expanded="false" aria-controls="collapseFeatures">
						Tính năng nổi bật
					</button>
				</h2>
				<div id="collapseFeatures" class="accordion-collapse collapse" aria-labelledby="headingFeatures" data-bs-parent="#productOptionalDetailsAccordion">
					<div class="accordion-body">
						<div class="form-group">
							<textarea asp-for="Features" class="form-control wysiwyg" rows="5"></textarea>
							<span asp-validation-for="Features" class="text-danger"></span>
						</div>
					</div>
				</div>
			</div>
			<div class="accordion-item">
				<h2 class="accordion-header" id="headingPackagingInfo">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapsePackagingInfo" aria-expanded="false" aria-controls="collapsePackagingInfo">
						Thông tin đóng gói
					</button>
				</h2>
				<div id="collapsePackagingInfo" class="accordion-collapse collapse" aria-labelledby="headingPackagingInfo" data-bs-parent="#productOptionalDetailsAccordion">
					<div class="accordion-body">
						<div class="form-group">
							<textarea asp-for="PackagingInfo" class="form-control wysiwyg" rows="5"></textarea>
							<span asp-validation-for="PackagingInfo" class="text-danger"></span>
						</div>
					</div>
				</div>
			</div>
			<div class="accordion-item">
				<h2 class="accordion-header" id="headingStorageInstructions">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseStorageInstructions" aria-expanded="false" aria-controls="collapseStorageInstructions">
						Hướng dẫn bảo quản
					</button>
				</h2>
				<div id="collapseStorageInstructions" class="accordion-collapse collapse" aria-labelledby="headingStorageInstructions" data-bs-parent="#productOptionalDetailsAccordion">
					<div class="accordion-body">
						<div class="form-group">
							<textarea asp-for="StorageInstructions" class="form-control wysiwyg" rows="5"></textarea>
							<span asp-validation-for="StorageInstructions" class="text-danger"></span>
						</div>
					</div>
				</div>
			</div>
			<div class="accordion-item">
				<h2 class="accordion-header" id="headingSafetyInfo">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSafetyInfo" aria-expanded="false" aria-controls="collapseSafetyInfo">
						Thông tin an toàn
					</button>
				</h2>
				<div id="collapseSafetyInfo" class="accordion-collapse collapse" aria-labelledby="headingSafetyInfo" data-bs-parent="#productOptionalDetailsAccordion">
					<div class="accordion-body">
						<div class="form-group">
							<textarea asp-for="SafetyInfo" class="form-control wysiwyg" rows="5"></textarea>
							<span asp-validation-for="SafetyInfo" class="text-danger"></span>
						</div>
					</div>
				</div>
			</div>
			<div class="accordion-item">
				<h2 class="accordion-header" id="headingApplicationAreas">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseApplicationAreas" aria-expanded="false" aria-controls="collapseApplicationAreas">
						Lĩnh vực ứng dụng
					</button>
				</h2>
				<div id="collapseApplicationAreas" class="accordion-collapse collapse" aria-labelledby="headingApplicationAreas" data-bs-parent="#productOptionalDetailsAccordion">
					<div class="accordion-body">
						<div class="form-group">
							<textarea asp-for="ApplicationAreas" class="form-control wysiwyg" rows="5"></textarea>
							<span asp-validation-for="ApplicationAreas" class="text-danger"></span>
						</div>
					</div>
				</div>
			</div>
			<div class="accordion-item">
				<h2 class="accordion-header" id="headingTechnicalDocuments">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTechnicalDocuments" aria-expanded="false" aria-controls="collapseTechnicalDocuments">
						Tài liệu kỹ thuật
					</button>
				</h2>
				<div id="collapseTechnicalDocuments" class="accordion-collapse collapse" aria-labelledby="headingTechnicalDocuments" data-bs-parent="#productOptionalDetailsAccordion">
					<div class="accordion-body">
						<div class="form-group">
							<textarea asp-for="TechnicalDocuments" class="form-control wysiwyg" rows="5"></textarea>
							<span asp-validation-for="TechnicalDocuments" class="text-danger"></span>
						</div>
					</div>
				</div>
			</div>
		</div>


	</div> @* End Left Column *@

	<div class="col-md-4">
		@* Right column for metadata/settings *@

		<div class="form-group mb-3">
			<label asp-for="CategoryId" class="form-label"></label>
			<select asp-for="CategoryId" asp-items="@Model.CategoryOptions" class="form-select"></select>
			<span asp-validation-for="CategoryId" class="text-danger"></span>
		</div>

		<div class="form-group mb-3">
			<label asp-for="BrandId" class="form-label"></label>
			<select asp-for="BrandId" asp-items="@Model.BrandOptions" class="form-select"></select>
			<span asp-validation-for="BrandId" class="text-danger"></span>
		</div>

		<div class="form-group mb-3">
			<label asp-for="Status" class="form-label required"></label>
			<select asp-for="Status" asp-items="@Model.StatusOptions" class="form-select"></select>
			<span asp-validation-for="Status" class="text-danger"></span>
		</div>

		<div class="form-check form-switch mb-0 mt-3">
			<input class="form-check-input" type="checkbox" asp-for="IsFeatured" role="switch">
			<label class="form-check-label" asp-for="IsFeatured"></label>
			<span asp-validation-for="IsFeatured" class="text-danger"></span>
		</div>

		<div class="form-check form-switch mb-0 mt-3">
			<input class="form-check-input" type="checkbox" asp-for="IsActive" role="switch">
			<label class="form-check-label" asp-for="IsActive"></label>
			<span asp-validation-for="IsActive" class="text-danger"></span>
		</div>

		@* --- Related Items (Tags, Articles) --- *@
		<hr class="my-3">
		<h4 class="mb-3">Liên kết</h4>

		<div class="form-group mb-3">
			<label asp-for="SelectedTagIds" class="form-label"></label>
			<select asp-for="SelectedTagIds" asp-items="@Model.AvailableTags" class="form-select" multiple></select>
			<span asp-validation-for="SelectedTagIds" class="text-danger"></span>
		</div>

		<div class="form-group mb-3">
			<label asp-for="SelectedArticleIds" class="form-label"></label>
			<select asp-for="SelectedArticleIds" asp-items="@Model.AvailableArticles" class="form-select" multiple></select>
			<span asp-validation-for="SelectedArticleIds" class="text-danger"></span>
			<small class="form-hint">Chọn các bài viết liên quan đến sản phẩm này.</small>
		</div>

	</div> @* End Right Column *@
</div> @* End Row g-3 *@


@* --- Product Images Section --- *@
<div class="card mt-4">
	<div class="card-header">
		<h3 class="card-title">Ảnh sản phẩm</h3>
	</div>
	<div class="card-body">
		@* Include a validation summary specifically for image errors *@
		<div id="product-image-validation-summary" class="text-danger mb-3">
			@* Validation messages for the Images collection will be placed here by client-side validation *@
			<span asp-validation-for="Images" class="text-danger"></span>
		</div>
		@* Render the partial for image management *@
		<partial name="_ProductImagesFormSection" model="Model.Images" />
	</div>
</div>

@* --- SEO Section (Using the shared partial) --- *@
<div class="card mt-4">
	<div class="card-header">
		<h3 class="card-title">Tối ưu SEO</h3>
	</div>
	<div class="card-body">
		<partial name="Components/Crud/_SeoFormFields" model="Model.Seo" />
	</div>
</div>

@*
@section Scripts {
	<script>
		$(document).ready(function() {
			const $imageContainer = $('#product-images-container');
			const $addImageButton = $('#add-image-button');
			let imageIndex = @(Model?.Count ?? 0);

			 // Template for a new image item form section
			 // Use __INDEX__ as a placeholder to be replaced by the actual index
			const imageItemTemplate = `
				<div class="row g-3 mb-3 product-image-item" data-index="__INDEX__">
					<input type="hidden" name="Images[__INDEX__]._Delete" value="False" class="image-delete-flag" />
					<input type="hidden" name="Images[__INDEX__].Id" value="0" /> 

					<div class="col-md-2 col-preview d-flex align-items-center justify-content-center border rounded p-2">
						<i class="ti ti-photo text-muted" style="font-size: 3rem;"></i>
					</div>

					<div class="col-md-9">
						<div class="form-group mb-2">
							<label for="Images___INDEX___ImageUrl" class="form-label">@Html.DisplayNameFor(model => model![0].ImageUrl)</label>
							<div class="input-group">
								<input type="url" id="Images___INDEX___ImageUrl" name="Images[__INDEX__].ImageUrl" class="form-control media-url-input image-url" value="" readonly />
								<button class="btn btn-outline-secondary select-media-button" type="button"
										data-bs-toggle="modal" data-bs-target="#selectMediaModal"
										data-media-type-filter="0">
									<i class="ti ti-photo"></i> Chọn
								</button>
							</div>
							 <span class="text-danger field-validation-valid" data-valmsg-for="Images[__INDEX__].ImageUrl" data-valmsg-replace="true"></span>
						</div>
						<div class="form-group mb-2">
							<label for="Images___INDEX___AltText" class="form-label">@Html.DisplayNameFor(model => model![0].AltText)</label>
							<input type="text" id="Images___INDEX___AltText" name="Images[__INDEX__].AltText" class="form-control" value="" />
							<span class="text-danger field-validation-valid" data-valmsg-for="Images[__INDEX__].AltText" data-valmsg-replace="true"></span>
						</div>
						<div class="row g-2">
							 <div class="col-md-6">
								 <div class="form-group mb-2">
									<label for="Images___INDEX___Title" class="form-label">@Html.DisplayNameFor(model => model![0].Title)</label>
									<input type="text" id="Images___INDEX___Title" name="Images[__INDEX__].Title" class="form-control" value="" />
									<span class="text-danger field-validation-valid" data-valmsg-for="Images[__INDEX__].Title" data-valmsg-replace="true"></span>
								</div>
							 </div>
							 <div class="col-md-3">
								 <div class="form-group mb-2">
									<label for="Images___INDEX___OrderIndex" class="form-label">@Html.DisplayNameFor(model => model![0].OrderIndex)</label>
									<input type="number" id="Images___INDEX___OrderIndex" name="Images[__INDEX__].OrderIndex" class="form-control" value="0" min="0" />
									 <span class="text-danger field-validation-valid" data-valmsg-for="Images[__INDEX__].OrderIndex" data-valmsg-replace="true"></span>
								</div>
							 </div>
							  <div class="col-md-3">
								 <label class="form-label"> </label>
								 <div class="form-check form-switch pt-2">
									 <input type="checkbox" id="Images___INDEX___IsMain" name="Images[__INDEX__].IsMain" value="true" class="form-check-input is-main-checkbox" role="switch">
									 <input type="hidden" name="Images[__INDEX__].IsMain" value="false">
									 <label for="Images___INDEX___IsMain" class="form-check-label">@Html.DisplayNameFor(model => model![0].IsMain)</label>
									 <span class="text-danger field-validation-valid" data-valmsg-for="Images[__INDEX__].IsMain" data-valmsg-replace="true"></span>
								 </div>
							 </div>
						 </div>
					</div>

					 <div class="col-md-1 d-flex align-items-center justify-content-end">
						 <button type="button" class="btn btn-icon btn-outline-danger remove-image-button" title="Xóa ảnh">
							 <i class="ti ti-trash"></i>
						 </button>
					 </div>
				</div>
			`;

			 // Function to add a new image item to the form
			function addImageItem(imageUrl = '', thumbnailUrl = '', altText = '', title = '') {
				const newItemHtml = imageItemTemplate.replace(/__INDEX__/g, imageIndex);
				const $newItem = $(newItemHtml);

				 // Pre-fill URL if provided (e.g., from Media Picker)
				if (imageUrl) {
					 $newItem.find('.media-url-input.image-url').val(imageUrl);
					 const $previewCol = $newItem.find('.col-preview');
					  $previewCol.empty().append(`<img src="${thumbnailUrl || imageUrl}" class="img-thumbnail" style="max-width: 80px; height: auto;" data-full-url="${imageUrl}" />`);
				}

				$imageContainer.append($newItem);

				// Re-parse validation for the new item (needed for client-side validation)
				// Ensure the form is available for the validator
				const $form = $imageContainer.closest('form');
				$form.removeData('validator').removeData('unobtrusiveValidation');
				$.validator.unobtrusive.parse($form);


				imageIndex++; // Increment index for the next item
			}

			 // Handle "Add Image" button click
			$addImageButton.on('click', function() {
				 addImageItem(); // Add a blank item by default
				 // Optionally, trigger Media Picker immediately after adding?
				 // $(this).prev('.product-image-item').find('.select-media-button').click(); // Example
			});

			 // Handle "Remove Image" button click (using event delegation)
			$imageContainer.on('click', '.remove-image-button', function() {
				const $itemToRemove = $(this).closest('.product-image-item');
				const $deleteFlag = $itemToRemove.find('.image-delete-flag');
				const imageId = $itemToRemove.find('input[name$=".Id"]').val();

				if (imageId > 0) {
					 // Mark existing image for deletion instead of removing from DOM
					 $deleteFlag.val('True');
					 $itemToRemove.addClass('d-none'); // Hide the item visually
					 // You might want to add a confirmation message or a way to undo deletion
					 console.log(`Marked image ${imageId} for deletion.`);

					 // Re-validate the form to update validation messages
					 const $form = $imageContainer.closest('form');
					 $form.validate().element($itemToRemove.find('.image-url')); // Trigger validation for one element to refresh summary
				} else {
					// Remove new images (ID 0) directly from DOM
					$itemToRemove.remove();
					console.log("Removed new image item.");
					 // Re-index remaining items if necessary (more complex, maybe skip for now)
				}
				// Re-index logic is needed if you remove from the middle.
				// A simpler approach for MVC binding is just hiding/marking for delete.
			});


			// Handle Media Picker Selection within the image list (using event delegation)
			// Assumes MediaManager.openMediaModal and the modal are initialized in __LibScripts
			 $imageContainer.on('click', '.select-media-button', function() {
				 const targetInput = $(this).closest('.input-group').find('.media-url-input');
				 const mediaTypeFilter = $(this).data('media-type-filter'); // Get filter from button data
				 const $previewCol = $(this).closest('.product-image-item').find('.col-preview');

				 window.openMediaModal(targetInput, function(selectedFile) {
					  // Callback after file is selected
					  // Update the URL input
					  targetInput.val(selectedFile.url).trigger('change'); // Trigger change for validation/binding

					   // Update the preview area
					  $previewCol.empty().append(`<img src="${selectedFile.url}" class="img-thumbnail" style="max-width: 80px; height: auto;" data-full-url="${selectedFile.url}" />`); // Use selectedFile.url for both thumb/full if thumb is not separate

					  // Optionally update AltText/Title if MediaManager provides them
					   if (selectedFile.altText && $item.find('input[name$=".AltText"]').val() === '') {
							targetInput.closest('.product-image-item').find('input[name$=".AltText"]').val(selectedFile.altText);
					   }
						if (selectedFile.title && $item.find('input[name$=".Title"]').val() === '') {
							targetInput.closest('.product-image-item').find('input[name$=".Title"]').val(selectedFile.title);
					   }

					 // Re-validate the specific input field
					 targetInput.valid();

				 }, mediaTypeFilter); // Pass filter to openMediaModal
			 });

			 // Handle IsMain checkbox logic (using event delegation)
			 $imageContainer.on('change', '.is-main-checkbox', function() {
				 const $currentCheckbox = $(this);
				 if ($currentCheckbox.is(':checked')) {
					 // Uncheck all other IsMain checkboxes in this container
					 $imageContainer.find('.is-main-checkbox').not($currentCheckbox).prop('checked', false);

					 // Ensure the hidden false input is correctly handled for others (unchecking removes value=true)
					 // This is complex with pure JS. jQuery Unobtrusive Validation handles the hidden field.
					 // A simpler approach is often to let the *server-side* validation ensure only one is true on POST.
					 // However, client-side validation can give instant feedback. FluentValidation's client-side adapter might handle this correctly if setup.

					  // If using manual JS for hidden field:
					  // $imageContainer.find('.is-main-checkbox').not($currentCheckbox).each(function() {
					  //     $(this).next('input[type="hidden"][name]').val('false');
					  // });
					   // $currentCheckbox.next('input[type="hidden"][name]').val('true'); // Not needed if value="true" attribute is set and model binding works


					 // Trigger validation for all IsMain checkboxes to update the validation summary
					  $imageContainer.find('.is-main-checkbox').valid();
				 } else {
					 // If unchecked, make sure there's still at least one main image selected if required by validator.
					 // Or just let the validator handle it on submit.
					  $currentCheckbox.valid(); // Validate just this one
					  // Also trigger validation for others if needed to clear messages
					  $imageContainer.find('.is-main-checkbox').not($currentCheckbox).valid();
				 }
			 });


			 // Client-side validation messages for the Images collection itself
			 // will appear in the div#product-image-validation-summary
			 // field-validation-valid spans are added next to each input by unobtrusive validation


		});
	</script>
}
*@